model Discount {
  discountId           Int               @id @default(autoincrement())
  name                 String
  discountValue        Decimal           @db.Decimal(10, 2)
  promotionType        PromotionType     @default(SALE)
  couponCode           String?           @unique
  minimumOrderTotal    Decimal?          @db.Decimal(10, 2)
  usageLimit           Int?
  usedCount            Int               @default(0)
  isActive             Boolean           @default(true)
  startsAt             DateTime?
  endsAt               DateTime?
  discountType         DiscountType
  discountScope        DiscountScope
  discountCategories   ProductCategory[] @default([])
  products             Product[]
  priority             Int               @default(0)
  newSaleNotifiedAt    DateTime?
  endingSoonNotifiedAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

enum PromotionType {
  SALE
  COUPON
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum DiscountScope {
  CATEGORY
  STORE
  PRODUCT
}
