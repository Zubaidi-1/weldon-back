enum ProductCategory {
  MELA_WHITE
  ESSENTIAL
  HYDRATING
  REGULATING
  SENSITIVE
  BEAUTY_ELEMENTS
  VITALITY
  BODY_SCIENCE
  HAIR
  MEN
  GREEN_PEEL
  NIGHT_CARE
  BODY_CARE
  AMPOULE
  DRY_SKIN
}

enum productStatus {
  ACTIVE
  DRAFT
  OUT_OF_STOCK
}

model Product {
  productId          Int               @id @default(autoincrement())
  productName        String
  productSubTitle    String?
  productPrice       Decimal
  productSize        Int
  stockQuantity      Int
  productSku         String            @unique()
  productDescription String
  productCategory    ProductCategory[] @default([])
  productStatus      productStatus
  productImage       String
  productImages      String[]          @default([])
  productShades      String[]          @default([])
  reviews            Review[]
  discounts          Discount[]
  cartItem           CartItem[]
  orderItems         OrderItem[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}
